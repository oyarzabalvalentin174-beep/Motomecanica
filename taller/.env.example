# PostgreSQL de Supabase (misma cadena que usas en local con DATABASE_URL).
# En Vercel conviene el pooler "Transaction" (puerto 6543) para funciones serverless.
# Supabase: Project Settings → Database → Connection string → URI
# Opcional en la query: uselibpqcompat=true (reduce warnings de sslmode con pg reciente)
DATABASE_URL=

# Si Postgres/Supabase falla en local con "self-signed certificate in certificate chain", probá:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# En producción dejalo sin definir o en true si la conexión verifica bien el certificado.

# URL pública de la app. En producción: https://tu-proyecto.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Secreto para firmar sesiones (mismo valor que en local si ya tienes NEXTAUTH_SECRET).
# Generar uno nuevo: openssl rand -base64 32
NEXTAUTH_SECRET=

# Opcional: NextAuth v4 también lee AUTH_SECRET si está definido (igual que NEXTAUTH_SECRET).
# AUTH_SECRET=
