# PostgreSQL de Supabase (misma cadena que usas en local con DATABASE_URL).
# En Vercel conviene el pooler "Transaction" (puerto 6543) para funciones serverless.
# Supabase: Project Settings → Database → Connection string → URI
DATABASE_URL=

# URL pública de la app. En producción: https://tu-proyecto.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Secreto para firmar sesiones (mismo valor que en local si ya tienes NEXTAUTH_SECRET).
# Generar uno nuevo: openssl rand -base64 32
NEXTAUTH_SECRET=

# Opcional: NextAuth v4 también lee AUTH_SECRET si está definido (igual que NEXTAUTH_SECRET).
# AUTH_SECRET=
